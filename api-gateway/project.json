{
  "name": "api-gateway",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "api-gateway/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/api-gateway"],
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production", "--output-path=../dist/api-gateway"],
        "cwd": "api-gateway"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development", "--output-path=../dist/api-gateway"]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api-gateway:build",
        "watch": true
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/api-gateway/package.json",
        "{workspaceRoot}/dist/api-gateway/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/api-gateway/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    }
  },
  "tags": []
}
